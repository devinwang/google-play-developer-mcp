# ============================================================
# CRITICAL — Never commit any of these. They contain
# credentials that grant full access to a Google Play account.
# ============================================================

# Service account key files
*.json.key
*service-account*.json
*service_account*.json
*-sa.json
*-sa-key.json
gcp-key*.json
google-credentials*.json
play-credentials*.json

# Env files
.env
.env.*
!.env.example

# Local account config (lives at ~/.google-play-developer-mcp/)
accounts.json
credentials/
keys/
secrets/

# Anything that looks like a key
*.pem
*.p12
*.pfx
*.key
id_rsa*
